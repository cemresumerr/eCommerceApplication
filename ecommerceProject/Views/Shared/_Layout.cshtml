<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ecommerceProject</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

    <style>
        /* Navbar modern style */
        .navbar {
            background: rgba(15, 32, 39, 0.8);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            margin: 10px 20px;
            padding: 10px 20px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
            position: relative;
            z-index: 1050;
        }

        .navbar-brand {
            font-weight: bold;
            font-size: 1.5rem;
            color: #f1f1f1 !important;
            letter-spacing: 1px;
        }

        .nav-link {
            color: #ddd !important;
            margin: 0 8px;
            transition: all 0.3s ease;
        }

            .nav-link:hover {
                color: #fff !important;
                transform: translateY(-2px);
            }

        .dropdown-menu {
            border-radius: 12px;
            padding: 10px;
            box-shadow: 0 6px 20px rgba(0,0,0,0.25);
            z-index: 9999 !important;
        }

        .dropdown-item {
            border-radius: 8px;
            transition: 0.3s;
        }

            .dropdown-item:hover {
                background-color: #2c5364;
                color: #fff !important;
            }

        /* Search box */
        .form-control {
            border-radius: 20px;
            padding: 8px 15px;
            border: 1px solid #444;
        }

        .btn-outline-success {
            border-radius: 20px;
            padding: 6px 14px;
            transition: 0.3s;
        }

            .btn-outline-success:hover {
                background-color: #2c5364;
                border-color: #2c5364;
                color: #fff;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Movies" asp-action="Index">🎬 eTickets</a>
                <button class="navbar-toggler text-light" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list"></i>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Movies" asp-action="Index">
                                <i class="bi bi-film"></i> Movies
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-gear"></i> Management
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                <li><a class="dropdown-item" asp-controller="Cinema" asp-action="Index"><i class="bi bi-camera-reels"></i> Cinemas</a></li>
                                <li><a class="dropdown-item" asp-controller="Producers" asp-action="Index"><i class="bi bi-headset"></i> Producers</a></li>
                                <li><a class="dropdown-item" asp-controller="Actors" asp-action="Index"><i class="bi bi-person-square"></i> Actors</a></li>
                            </ul>
                        </li>
                    </ul>

                    <form class="d-flex" asp-controller="Movies" asp-action="Filter">
                        <input name="searchString" class="form-control me-2" type="search" placeholder="Search movie..." aria-label="Search">
                        <button class="btn btn-outline-success" type="submit"><i class="bi bi-search"></i></button>
                    </form>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - eTickets
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
















